              }}
              onMouseEnter={e=>{if(isUnlocked){e.currentTarget.style.transform="scale(1.1)";e.currentTarget.style.borderColor=DIFF_COLOR[l.diff];}}}
              onMouseLeave={e=>{e.currentTarget.style.transform="scale(1)";e.currentTarget.style.borderCol